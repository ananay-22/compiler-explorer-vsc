{
    "name": "compiler-explorer",
    "displayName": "Compiler Explorer",
    "description": "Use Compiler Explorer in VSCode",
    "version": "0.4.3",
    "publisher": "ananay-22",
    "license": "MIT",
    "homepage": "https://github.com/ananay-22/compiler-explorer-vsc.git",
    "icon": "images/Compiler-Explorer-VSCode.png",
    "galleryBanner": {
        "color": "#1F1F1F",
        "theme": "dark"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ananay-22/compiler-explorer-vsc.git"
    },
    "bugs": {
        "url": "https://github.com/MRobertEvers/vscode-compiler-explorer/issues"
    },
    "engines": {
        "vscode": "^1.42.0"
    },
    "categories": [
        "Debuggers"
    ],
    "keywords": [
        "compiler-explorer",
        "compiler"
    ],
    "activationEvents": [
        "*"
    ],
    "main": "./build/vscode-compiler-explorer",
    "contributes": {
        "configuration": {
            "title": "Compiler Explorer Configuration",
            "properties": {
                "compiler-explorer.url": {
                    "type": "string",
                    "default": "https://godbolt.org",
                    "description": "URL of compiler explorer.",
                    "scope": "window"
                },
                "compiler-explorer.compilerDefault": {
                    "type": "string",
                    "default": "g92",
                    "description": "Compiler code to use for unchecked file types",
                    "scope": "window"
                },
                "compiler-explorer.compilerCpp": {
                    "type": "string",
                    "default": "g92",
                    "description": "Compiler code to use for c/c++ files",
                    "scope": "window"
                },
                "compiler-explorer.compilerPython": {
                    "type": "string",
                    "default": "python39",
                    "description": "Compiler code to use for python files",
                    "scope": "window"
                },
                "compiler-explorer.compilerJava": {
                    "type": "string",
                    "default": "java1102",
                    "description": "Compiler code to use for java files",
                    "scope": "window"
                },
                "compiler-explorer.optionsCpp": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "-O3"
                    ],
                    "description": "Compiler options.",
                    "scope": "window"
                },
                "compiler-explorer.optionsJava": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        ""
                    ],
                    "description": "Compiler options.",
                    "scope": "window"
                },
                "compiler-explorer.optionsPython": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        ""
                    ],
                    "description": "Compiler options.",
                    "scope": "window"
                },
                "compiler-explorer.optionsDefault": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        ""
                    ],
                    "description": "Compiler options.",
                    "scope": "window"
                },
                "compiler-explorer.debug": {
                    "type": "boolean",
                    "default": false,
                    "description": "Include debug printouts.",
                    "scope": "window"
                },
                "compiler-explorer.include": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Additional includes if running compiler explorer locally.",
                    "scope": "window"
                }
            }
        },
        "commands": [
            {
                "title": "Open Compiler Explorer",
                "category": "compiler-explorer",
                "icon": "$(play)",
                "command": "compiler-explorer.open"
            },
            {
                "title": "Update Compiler Explorer",
                "category": "compiler-explorer",
                "icon": "$(refresh)",
                "command": "compiler-explorer.updateDisassembly"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "compiler-explorer.open",
                    "when": "resourceExtname == .c || resourceExtname == .cpp || resourceExtname == .py || resourceExtname == .java",
                    "group": "navigation"
                }
            ],
            "explorer/context": [
                {
                    "command": "compiler-explorer.open",
                    "when": "resourceExtname == .c || resourceExtname == .cpp || resourceExtname == .py || resourceExtname == .java",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "build": "webpack --mode none",
        "watch": "webpack --mode none --watch",
        "pretest": "tsc -p ./",
        "test": "node ./build/src/test/runTest.js"
    },
    "dependencies": {
        "node-fetch": "^2.6.0"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^12.12.14",
        "@types/node-fetch": "^2.5.5",
        "@types/vscode": "^1.42.0",
        "@types/webpack": "^4.41.7",
        "@vscode/test-electron": "^2.5.2",
        "mocha": "^11.7.5",
        "ts-loader": "^6.2.1",
        "ts-node": "^8.6.2",
        "typescript": "^3.8.3",
        "vsce": "^1.74.0",
        "webpack": "^4.41.6",
        "webpack-cli": "^3.3.12"
    }
}